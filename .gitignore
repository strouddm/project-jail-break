# Python Virtual Environment and Caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Environment variables

venv/
.venv/
env/

# Data — ignore contents but keep the dirs tracked via .gitkeep
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Models and Artifacts — ignore contents but keep the dir tracked via .gitkeep
*.pkl
*.pt
*.bin
models/*
!models/.gitkeep

# OS and IDE
.DS_Store
.vscode/
.idea/


